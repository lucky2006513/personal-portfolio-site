---
import Container from '@/components/Container.astro';
import { withBase } from '@/lib/paths';
import { profile, site } from '@/lib/site';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props as Props;
const normalizedCurrentPath = currentPath.replace(/\/$/, '') || '/';
const siteName = profile.name === '待补充姓名' ? site.title : `${profile.name} 的作品集`;

function isActive(href: string) {
  const normalizedTarget = withBase(href).replace(/\/$/, '') || '/';
  return normalizedCurrentPath === normalizedTarget || (href !== '/' && normalizedCurrentPath.startsWith(normalizedTarget));
}
---

<header class="pt-5 sm:pt-6">
  <Container>
    <div class="surface-card flex flex-col gap-4 rounded-[1.75rem] px-5 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6">
      <a class="font-serif text-lg text-stone-900" href={withBase('/')}>
        {siteName}
      </a>

      <nav aria-label="主导航">
        <ul class="flex flex-wrap gap-2 sm:justify-end">
          {site.navigation.map((item) => (
            <li>
              <a
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'inline-flex rounded-full px-4 py-2 text-sm transition',
                  isActive(item.href)
                    ? 'bg-stone-900 text-stone-50'
                    : 'text-stone-600 hover:bg-orange-50 hover:text-stone-900',
                ]}
                href={withBase(item.href)}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </Container>
</header>
