---
import type { ProjectEntry } from '@/lib/projects';
import { withBase } from '@/lib/paths';

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props as Props;
const href = withBase(`/projects/${project.data.slug}`);
---

<article class="surface-card group flex h-full flex-col rounded-[2rem] p-6 transition duration-300 hover:-translate-y-1">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-sm uppercase tracking-[0.18em] text-stone-500">{project.data.year}</p>
      <h3 class="mt-2 font-serif text-2xl text-stone-900">{project.data.title}</h3>
    </div>
    <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-900">
      {project.data.status}
    </span>
  </div>

  <p class="mt-4 text-sm leading-7 text-stone-600">{project.data.summary}</p>

  <p class="mt-5 text-sm font-medium text-stone-900">角色：{project.data.role}</p>

  <ul class="mt-4 flex flex-wrap gap-2">
    {project.data.stack.map((item) => (
      <li class="rounded-full border border-orange-200/70 bg-orange-50 px-3 py-1 text-xs text-orange-900">
        {item}
      </li>
    ))}
  </ul>

  {project.data.highlights.length > 0 && (
    <ul class="mt-5 space-y-2 text-sm leading-7 text-stone-600">
      {project.data.highlights.slice(0, 2).map((item) => (
        <li class="flex gap-3">
          <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  )}

  <div class="mt-6 flex items-center justify-between border-t border-orange-100 pt-5">
    <span class="text-sm text-stone-500">查看项目详情与复盘</span>
    <a class="text-sm font-semibold text-stone-900 transition group-hover:text-orange-700" href={href}>
      查看详情
    </a>
  </div>
</article>
