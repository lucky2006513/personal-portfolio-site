---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props as Props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="mt-4 font-serif text-3xl tracking-tight text-stone-900 sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-8 text-stone-600 sm:text-lg">{description}</p>}
</div>
