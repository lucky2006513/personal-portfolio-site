---
import Container from '@/components/Container.astro';
import { profile, site } from '@/lib/site';

const currentYear = new Date().getFullYear();
---

<footer class="pb-10 pt-16">
  <Container>
    <div class="surface-card rounded-[2rem] px-6 py-8 sm:px-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="font-serif text-2xl text-stone-900">{site.title}</p>
          <p class="mt-3 text-sm leading-7 text-stone-600">{site.footerNote}</p>
        </div>

        <div class="text-sm leading-7 text-stone-500">
          <p>{profile.location}</p>
          <p>{profile.availability}</p>
          <p class="mt-2">© {currentYear} Portfolio v1</p>
        </div>
      </div>
    </div>
  </Container>
</footer>
