---
import { withBase } from '@/lib/paths';

interface Props {
  title: string;
  description: string;
  actionLabel?: string;
  actionHref?: string;
}

const { title, description, actionLabel, actionHref } = Astro.props as Props;
---

<section class="surface-card rounded-[2rem] p-8 sm:p-10">
  <div class="max-w-2xl">
    <span class="eyebrow">内容待补充</span>
    <h3 class="mt-4 font-serif text-2xl text-stone-900">{title}</h3>
    <p class="mt-4 text-base leading-8 text-stone-600">{description}</p>
    {actionLabel && actionHref && (
      <a
        class="mt-6 inline-flex items-center rounded-full bg-stone-900 px-5 py-3 text-sm font-medium text-stone-50 transition hover:bg-stone-700"
        href={withBase(actionHref)}
      >
        {actionLabel}
      </a>
    )}
  </div>
</section>
