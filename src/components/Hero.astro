---
import { profile, site } from '@/lib/site';
import { withBase } from '@/lib/paths';

interface Props {
  projectCount: number;
  featuredCount: number;
}

const { projectCount, featuredCount } = Astro.props as Props;
const heroTitle = profile.name === '待补充姓名' ? '正在搭建中的个人作品集' : `${profile.name} 的个人作品集`;
---

<section class="page-grid lg:grid-cols-[1.3fr_0.9fr] lg:items-stretch lg:gap-8">
  <div class="surface-card fade-up rounded-[2rem] p-8 sm:p-10 lg:p-12">
    <span class="eyebrow">Portfolio v1</span>
    <h1 class="mt-6 max-w-3xl font-serif text-4xl leading-tight text-stone-900 sm:text-5xl lg:text-6xl">
      {heroTitle}
    </h1>
    <p class="mt-4 max-w-2xl text-lg leading-8 text-stone-600">{profile.headline}</p>
    <p class="mt-6 max-w-2xl text-base leading-8 text-stone-600">{profile.tagline}</p>

    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <a
        class="inline-flex items-center justify-center rounded-full bg-stone-900 px-6 py-3 text-sm font-medium text-stone-50 transition hover:bg-stone-700"
        href={withBase(site.cta.primaryHref)}
      >
        {site.cta.primaryLabel}
      </a>
      <a
        class="inline-flex items-center justify-center rounded-full border border-orange-200 bg-white/70 px-6 py-3 text-sm font-medium text-stone-900 transition hover:border-orange-300 hover:bg-orange-50"
        href={withBase(site.cta.secondaryHref)}
      >
        {site.cta.secondaryLabel}
      </a>
    </div>
  </div>

  <div class="page-grid">
    <div class="surface-card fade-up fade-delay-1 rounded-[2rem] p-6 sm:p-8">
      <p class="text-sm uppercase tracking-[0.18em] text-stone-500">当前状态</p>
      <dl class="mt-5 grid gap-5 sm:grid-cols-3 lg:grid-cols-1">
        <div>
          <dt class="text-sm text-stone-500">目标方向</dt>
          <dd class="mt-2 font-serif text-2xl text-stone-900">全栈开发</dd>
        </div>
        <div>
          <dt class="text-sm text-stone-500">公开项目</dt>
          <dd class="mt-2 font-serif text-2xl text-stone-900">{projectCount} 个</dd>
        </div>
        <div>
          <dt class="text-sm text-stone-500">精选项目</dt>
          <dd class="mt-2 font-serif text-2xl text-stone-900">{featuredCount} 个</dd>
        </div>
      </dl>
    </div>

    <div class="surface-card fade-up fade-delay-2 rounded-[2rem] p-6 sm:p-8">
      <p class="text-sm uppercase tracking-[0.18em] text-stone-500">展示原则</p>
      <ul class="mt-5 space-y-3 text-sm leading-7 text-stone-600">
        <li class="flex gap-3">
          <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span>
          <span>真实内容优先，不用虚构经历填满页面。</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span>
          <span>用项目、技能和复盘来说明能力，而不是只堆术语。</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span>
          <span>内容不足时保留优雅空状态，方便后续持续迭代。</span>
        </li>
      </ul>
    </div>
  </div>
</section>
