---
import Container from '@/components/Container.astro';
import EmptyState from '@/components/EmptyState.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { profile } from '@/lib/site';
---

<BaseLayout title="关于我" currentPath={Astro.url.pathname}>
  <Container class="space-y-16 sm:space-y-20">
    <section class="surface-card rounded-[2rem] p-8 sm:p-10">
      <SectionHeading
        eyebrow="About"
        title="把个人定位、技能边界和成长路径说清楚"
        description="这页承担的是“理解你是谁、擅长什么、适合什么岗位”的任务，因此会优先保留真实信息结构，而不是用空泛形容词堆满。"
      />

      <div class="mt-8 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="space-y-4">
          {profile.intro.map((paragraph) => (
            <p class="text-base leading-8 text-stone-600">{paragraph}</p>
          ))}
        </div>

        <aside class="rounded-[1.75rem] border border-orange-100 bg-white/75 p-6">
          <p class="text-sm uppercase tracking-[0.18em] text-stone-500">当前信息状态</p>
          <dl class="mt-5 space-y-5">
            <div>
              <dt class="text-sm text-stone-500">姓名</dt>
              <dd class="mt-1 text-base font-medium text-stone-900">{profile.name}</dd>
            </div>
            <div>
              <dt class="text-sm text-stone-500">所在地</dt>
              <dd class="mt-1 text-base font-medium text-stone-900">{profile.location}</dd>
            </div>
            <div>
              <dt class="text-sm text-stone-500">求职状态</dt>
              <dd class="mt-1 text-base font-medium text-stone-900">{profile.availability}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="space-y-8">
      <SectionHeading
        eyebrow="能力聚焦"
        title="建议优先展示的三类能力"
        description="如果你暂时没有很多项目，也可以先把能力分组整理清楚，让招聘方更快知道你能解决什么问题。"
      />

      <div class="grid gap-6 md:grid-cols-3">
        {profile.focusAreas.map((item) => (
          <article class="surface-card rounded-[2rem] p-6">
            <p class="font-serif text-2xl text-stone-900">{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="space-y-8">
      <SectionHeading
        eyebrow="技能结构"
        title="按模块整理技能，而不是只列工具名"
        description="写技能时建议优先补充你真正做过的内容，例如做过哪些页面、接口、部署流程或工程化实践。"
      />

      <div class="grid gap-6 lg:grid-cols-3">
        {profile.skillGroups.map((group) => (
          <article class="surface-card rounded-[2rem] p-6">
            <h3 class="font-serif text-2xl text-stone-900">{group.name}</h3>
            <ul class="mt-5 space-y-3 text-sm leading-7 text-stone-600">
              {group.items.map((item) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-2">
      <div class="space-y-6">
        <SectionHeading
          eyebrow="经历"
          title="项目经历或实习经历"
          description="这里适合放可验证的真实经历。没有时就保留空状态，不需要强行编写。"
        />

        {profile.experience.length > 0 ? (
          <div class="space-y-4">
            {profile.experience.map((item) => (
              <article class="surface-card rounded-[2rem] p-6">
                <p class="text-sm uppercase tracking-[0.18em] text-stone-500">{item.period}</p>
                <h3 class="mt-3 font-serif text-2xl text-stone-900">{item.title}</h3>
                <p class="mt-1 text-sm font-medium text-orange-800">{item.org}</p>
                <p class="mt-4 text-sm leading-7 text-stone-600">{item.summary}</p>
              </article>
            ))}
          </div>
        ) : (
          <EmptyState
            title="还没有公开的项目或实习经历"
            description="后续可以补充课程项目、个人项目、兼职经历或实习经历，只保留真实可解释的内容。"
          />
        )}
      </div>

      <div class="space-y-6">
        <SectionHeading
          eyebrow="教育"
          title="教育背景或学习路径"
          description="如果正式学历信息暂时不方便公开，也可以先写正在学习的方向、课程或训练营。"
        />

        {profile.education.length > 0 ? (
          <div class="space-y-4">
            {profile.education.map((item) => (
              <article class="surface-card rounded-[2rem] p-6">
                <p class="text-sm uppercase tracking-[0.18em] text-stone-500">{item.period}</p>
                <h3 class="mt-3 font-serif text-2xl text-stone-900">{item.title}</h3>
                <p class="mt-1 text-sm font-medium text-orange-800">{item.org}</p>
                <p class="mt-4 text-sm leading-7 text-stone-600">{item.summary}</p>
              </article>
            ))}
          </div>
        ) : (
          <EmptyState
            title="教育或学习信息还没补充"
            description="建议至少补一条与目标岗位有关的学习路径，例如正在系统学习哪些技术、做过哪些训练型项目。"
          />
        )}
      </div>
    </section>
  </Container>
</BaseLayout>
