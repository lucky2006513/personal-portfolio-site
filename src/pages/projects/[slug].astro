---
import { render } from 'astro:content';
import Container from '@/components/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/paths';
import { getPublishedProjects, type ProjectEntry } from '@/lib/projects';

export async function getStaticPaths() {
  const projects = await getPublishedProjects();

  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: ProjectEntry };
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.summary} currentPath={Astro.url.pathname}>
  <Container class="space-y-10 sm:space-y-12">
    <nav aria-label="返回导航">
      <a class="inline-flex items-center text-sm font-medium text-stone-600 transition hover:text-stone-900" href={withBase('/projects')}>
        返回作品集
      </a>
    </nav>

    <article class="surface-card rounded-[2rem] p-8 sm:p-10">
      <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
        <div>
          <span class="eyebrow">Project Detail</span>
          <h1 class="mt-5 font-serif text-4xl text-stone-900 sm:text-5xl">{project.data.title}</h1>
          <p class="mt-5 max-w-3xl text-base leading-8 text-stone-600">{project.data.summary}</p>

          <div class="mt-6 flex flex-wrap gap-3">
            <span class="rounded-full bg-amber-100 px-4 py-2 text-sm text-amber-950">{project.data.status}</span>
            <span class="rounded-full bg-stone-100 px-4 py-2 text-sm text-stone-700">{project.data.year}</span>
            <span class="rounded-full bg-stone-100 px-4 py-2 text-sm text-stone-700">角色：{project.data.role}</span>
          </div>
        </div>

        <aside class="rounded-[1.75rem] border border-orange-100 bg-white/75 p-6">
          <p class="text-sm uppercase tracking-[0.18em] text-stone-500">技术栈</p>
          <ul class="mt-4 flex flex-wrap gap-2">
            {project.data.stack.map((item) => (
              <li class="rounded-full border border-orange-200/70 bg-orange-50 px-3 py-1 text-xs text-orange-900">
                {item}
              </li>
            ))}
          </ul>

          {project.data.links.length > 0 && (
            <div class="mt-8 space-y-3">
              <p class="text-sm uppercase tracking-[0.18em] text-stone-500">外部链接</p>
              <ul class="space-y-3">
                {project.data.links.map((link) => (
                  <li>
                    <a
                      class="inline-flex items-center text-sm font-medium text-stone-900 transition hover:text-orange-700"
                      href={link.url}
                      rel="noreferrer"
                      target="_blank"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>
      </div>

      {project.data.highlights.length > 0 && (
        <section class="mt-10 rounded-[1.75rem] border border-orange-100 bg-orange-50/60 p-6">
          <h2 class="font-serif text-2xl text-stone-900">项目亮点</h2>
          <ul class="mt-5 space-y-3 text-sm leading-7 text-stone-700">
            {project.data.highlights.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <section class="rounded-[1.75rem] border border-orange-100 bg-white/75 p-6">
          <h2 class="font-serif text-2xl text-stone-900">关键难点</h2>
          <p class="mt-4 text-sm leading-7 text-stone-600">{project.data.challenge}</p>
        </section>
        <section class="rounded-[1.75rem] border border-orange-100 bg-white/75 p-6">
          <h2 class="font-serif text-2xl text-stone-900">解决方案</h2>
          <p class="mt-4 text-sm leading-7 text-stone-600">{project.data.solution}</p>
        </section>
        <section class="rounded-[1.75rem] border border-orange-100 bg-white/75 p-6">
          <h2 class="font-serif text-2xl text-stone-900">结果与收获</h2>
          <p class="mt-4 text-sm leading-7 text-stone-600">{project.data.outcome}</p>
        </section>
      </div>

      <section class="article-copy mt-10 rounded-[1.75rem] border border-orange-100 bg-white/70 p-6 sm:p-8">
        <Content />
      </section>
    </article>
  </Container>
</BaseLayout>
