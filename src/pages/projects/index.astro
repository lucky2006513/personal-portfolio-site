---
import Container from '@/components/Container.astro';
import EmptyState from '@/components/EmptyState.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedProjects } from '@/lib/projects';
import { site } from '@/lib/site';

const projects = await getPublishedProjects();
---

<BaseLayout title="作品集" currentPath={Astro.url.pathname}>
  <Container class="space-y-12 sm:space-y-16">
    <section class="surface-card rounded-[2rem] p-8 sm:p-10">
      <SectionHeading
        eyebrow="Projects"
        title="围绕项目背景、关键难点与解决方案来展示能力"
        description="项目页是整个网站的核心。相比只放截图和技术名词，这里会更强调你在项目里具体做了什么，以及你是怎么做判断的。"
      />

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <article class="rounded-[1.5rem] border border-orange-100 bg-white/75 p-5">
          <p class="text-sm text-stone-500">公开项目</p>
          <p class="mt-3 font-serif text-3xl text-stone-900">{projects.length}</p>
        </article>
        <article class="rounded-[1.5rem] border border-orange-100 bg-white/75 p-5">
          <p class="text-sm text-stone-500">详情页结构</p>
          <p class="mt-3 font-serif text-3xl text-stone-900">已就绪</p>
        </article>
        <article class="rounded-[1.5rem] border border-orange-100 bg-white/75 p-5">
          <p class="text-sm text-stone-500">内容策略</p>
          <p class="mt-3 font-serif text-3xl text-stone-900">真实优先</p>
        </article>
      </div>
    </section>

    {projects.length > 0 ? (
      <section class="grid gap-6 lg:grid-cols-2">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </section>
    ) : (
      <EmptyState
        title="这里将展示你的真实项目"
        description={site.emptyProjectsMessage}
        actionHref="/about"
        actionLabel="先看个人信息结构"
      />
    )}
  </Container>
</BaseLayout>
