---
import Container from '@/components/Container.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { profile } from '@/lib/site';

const hasEmail = profile.email.trim() !== '';
const hasGitHub = profile.github.trim() !== '';
const hasSocialLinks = profile.socialLinks.length > 0;
---

<BaseLayout title="联系我" currentPath={Astro.url.pathname}>
  <Container class="space-y-12 sm:space-y-16">
    <section class="surface-card rounded-[2rem] p-8 sm:p-10">
      <SectionHeading
        eyebrow="Contact"
        title="首版保持静态联系方式，先保证稳定和真实"
        description="这里不接在线表单，也不接第三方消息服务。等你准备好公开信息后，只需要把邮箱、GitHub 或社交链接填进数据文件即可。"
      />

      <div class="mt-8 grid gap-6 lg:grid-cols-3">
        <article class="rounded-[1.75rem] border border-orange-100 bg-white/75 p-6">
          <p class="text-sm uppercase tracking-[0.18em] text-stone-500">邮箱</p>
          {hasEmail ? (
            <a class="mt-4 inline-flex text-base font-medium text-stone-900 underline decoration-orange-300 underline-offset-4" href={`mailto:${profile.email}`}>
              {profile.email}
            </a>
          ) : (
            <p class="mt-4 text-sm leading-7 text-stone-600">待补充常用邮箱。建议优先公开一个长期可用的联系地址。</p>
          )}
        </article>

        <article class="rounded-[1.75rem] border border-orange-100 bg-white/75 p-6">
          <p class="text-sm uppercase tracking-[0.18em] text-stone-500">GitHub</p>
          {hasGitHub ? (
            <a
              class="mt-4 inline-flex text-base font-medium text-stone-900 underline decoration-orange-300 underline-offset-4"
              href={profile.github}
              rel="noreferrer"
              target="_blank"
            >
              打开 GitHub 主页
            </a>
          ) : (
            <p class="mt-4 text-sm leading-7 text-stone-600">待补充 GitHub 主页链接。公开代码仓库有助于增强可信度。</p>
          )}
        </article>

        <article class="rounded-[1.75rem] border border-orange-100 bg-white/75 p-6">
          <p class="text-sm uppercase tracking-[0.18em] text-stone-500">社交链接</p>
          {hasSocialLinks ? (
            <ul class="mt-4 space-y-3">
              {profile.socialLinks.map((item) => (
                <li>
                  <a
                    class="inline-flex text-base font-medium text-stone-900 underline decoration-orange-300 underline-offset-4"
                    href={item.url}
                    rel="noreferrer"
                    target="_blank"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="mt-4 text-sm leading-7 text-stone-600">如果暂时没有其他公开账号，可以先保留空状态，不影响首版上线。</p>
          )}
        </article>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <article class="surface-card rounded-[2rem] p-8">
        <p class="text-sm uppercase tracking-[0.18em] text-stone-500">补充建议</p>
        <h2 class="mt-4 font-serif text-3xl text-stone-900">准备公开联系方式时，可以按这个顺序来</h2>
        <ul class="mt-6 space-y-3 text-sm leading-7 text-stone-600">
          {profile.contactHints.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </article>

      <article class="surface-card rounded-[2rem] p-8">
        <p class="text-sm uppercase tracking-[0.18em] text-stone-500">说明</p>
        <h2 class="mt-4 font-serif text-3xl text-stone-900">为什么首版不做联系表单</h2>
        <div class="mt-5 space-y-4 text-sm leading-7 text-stone-600">
          <p>静态联系方式更稳定，部署更简单，也不需要数据库、邮件服务或防垃圾内容策略。</p>
          <p>对于求职向个人站来说，公开一个常用邮箱和 GitHub 链接，通常已经足够支撑首轮沟通。</p>
          <p>如果后续你确实需要在线表单，可以在二期接入表单服务，但不建议把这件事阻塞首版上线。</p>
        </div>
      </article>
    </section>
  </Container>
</BaseLayout>
