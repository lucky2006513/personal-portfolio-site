---
import Container from '@/components/Container.astro';
import EmptyState from '@/components/EmptyState.astro';
import Hero from '@/components/Hero.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/paths';
import { getFeaturedProjects, getPublishedProjects } from '@/lib/projects';
import { profile, site } from '@/lib/site';

const featuredProjects = await getFeaturedProjects();
const allProjects = await getPublishedProjects();
---

<BaseLayout currentPath={Astro.url.pathname}>
  <Container class="space-y-16 sm:space-y-20">
    <Hero featuredCount={featuredProjects.length} projectCount={allProjects.length} />

    <section class="page-grid gap-6 lg:grid-cols-3">
      <article class="surface-card fade-up rounded-[2rem] p-6">
        <p class="text-sm uppercase tracking-[0.18em] text-stone-500">内容策略</p>
        <h2 class="mt-4 font-serif text-2xl text-stone-900">先结构完整，再补真实内容</h2>
        <p class="mt-4 text-sm leading-7 text-stone-600">
          当前版本优先把页面结构、视觉系统、路由、内容接口和部署流程搭好，方便后续逐步替换成真实项目与经历。
        </p>
      </article>

      <article class="surface-card fade-up fade-delay-1 rounded-[2rem] p-6">
        <p class="text-sm uppercase tracking-[0.18em] text-stone-500">展示重点</p>
        <h2 class="mt-4 font-serif text-2xl text-stone-900">用作品说话</h2>
        <p class="mt-4 text-sm leading-7 text-stone-600">
          作品详情页会优先讲清楚项目背景、技术选择、关键难点与结果收获，让面试方更容易看见你的判断和成长。
        </p>
      </article>

      <article class="surface-card fade-up fade-delay-2 rounded-[2rem] p-6">
        <p class="text-sm uppercase tracking-[0.18em] text-stone-500">后续维护</p>
        <h2 class="mt-4 font-serif text-2xl text-stone-900">按文件维护内容</h2>
        <p class="mt-4 text-sm leading-7 text-stone-600">
          新增项目时只需要补充数据文件，不需要修改模板页面。这能让你后续与其他智能体协作时更稳定，也更省心。
        </p>
      </article>
    </section>

    <section class="space-y-8">
      <SectionHeading
        eyebrow="精选项目"
        title="优先展示最能代表你的作品"
        description="首页只展示精选项目，完整列表与详情放在作品集页，方便招聘方快速理解你的代表性成果。"
      />

      {featuredProjects.length > 0 ? (
        <div class="grid gap-6 lg:grid-cols-3">
          {featuredProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      ) : (
        <EmptyState
          title="当前还没有公开的精选项目"
          description={site.emptyProjectsMessage}
          actionHref="/projects"
          actionLabel="先看作品集结构"
        />
      )}
    </section>

    <section class="page-grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="surface-card rounded-[2rem] p-8">
        <SectionHeading
          eyebrow="能力聚焦"
          title="这个网站会重点展示的方向"
          description="求职场景下，先把目标岗位、能力边界和作品类型表达清楚，比追求内容数量更重要。"
        />

        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          {profile.focusAreas.map((item) => (
            <article class="rounded-[1.5rem] border border-orange-100 bg-white/70 p-5">
              <p class="text-sm leading-7 text-stone-700">{item}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="surface-card rounded-[2rem] p-8">
        <p class="text-sm uppercase tracking-[0.18em] text-stone-500">下一步建议</p>
        <h2 class="mt-4 font-serif text-3xl text-stone-900">后续补内容时的优先级</h2>
        <ul class="mt-6 space-y-3 text-sm leading-7 text-stone-600">
          {profile.currentlyDoing.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-orange-400"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a
          class="mt-8 inline-flex items-center rounded-full border border-orange-200 bg-white/80 px-5 py-3 text-sm font-medium text-stone-900 transition hover:bg-orange-50"
          href={withBase('/about')}
        >
          查看完整个人信息结构
        </a>
      </div>
    </section>

    <section class="surface-card rounded-[2rem] p-8 sm:p-10">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="eyebrow">联系入口</span>
          <h2 class="mt-4 font-serif text-3xl text-stone-900 sm:text-4xl">准备好真实联系方式后，再公开也完全来得及</h2>
          <p class="mt-4 text-base leading-8 text-stone-600">
            首版不做在线表单，只放静态联系方式。这样更稳定，也更适合先完成求职展示站的基础搭建。
          </p>
        </div>
        <a
          class="inline-flex items-center justify-center rounded-full bg-stone-900 px-6 py-3 text-sm font-medium text-stone-50 transition hover:bg-stone-700"
          href={withBase('/contact')}
        >
          前往联系页
        </a>
      </div>
    </section>
  </Container>
</BaseLayout>
